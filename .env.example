# Wushi Website Environment Variables Template

# APP_URL: The URL where this site is hosted.
# Used for self-referential links, sitemaps, and absolute metadata URLs.
APP_URL="https://www.cqwushi.com"

# Lead inbox email (required)
LEAD_TO_EMAIL="your-email@example.com"

# Sender identity (optional, must match your Resend verified domain)
LEAD_FROM_EMAIL="Wushi Leads <onboarding@resend.dev>"

# Resend API key (required)
# Obtain from https://resend.com
RESEND_API_KEY="re_..."
